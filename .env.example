# ===== Wine Photo Verification — Environment =====

# Runtime
APP_ENV=production
DEBUG=false

# URLs (used inside docker network and for CORS)
API_BASE_URL=http://backend:8000
FRONTEND_URL=https://your-domain.example.com

# ----- Search -----
# `auto` uses SerpAPI when SERPAPI_KEY is set, otherwise falls through to Bing/Playwright
SEARCH_PROVIDER=auto
SERPAPI_KEY=

# ----- AI / VLM -----
# Recommended: a single OpenRouter key handles both Gemini and Qwen-VL
OPENROUTER_API_KEY=sk-or-v1-...

# Optional native keys (used directly when valid, otherwise we fall back to OpenRouter)
GEMINI_API_KEY=
QWEN_API_KEY=
QWEN_BASE_URL=https://openrouter.ai/api/v1

# ----- OCR -----
OCR_ENGINE=easyocr

# ----- Scoring -----
DEFAULT_ANALYZER_MODE=hybrid_fast
PASS_THRESHOLD=25
REVIEW_THRESHOLD=15

# ----- Optional: VinoBuzz catalogue scrape -----
VINOBUZZ_SESSION_ID=
